<Window x:Class="AskaServerManager.LogViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Log Viewer" Height="500" Width="700"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Background="#121212" Foreground="#D4A017">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Browse button -->
        <Button x:Name="BtnBrowse" Content="Browse..." Width="80" Click="Browse_Click"/>

        <!-- Filter panel: dynamic rows with ComboBox and "-" button -->
        <StackPanel x:Name="FilterContainer" Grid.Row="1" Margin="0,10,0,10" Orientation="Vertical"/>

        <!-- "+" button to add filter -->
        <Button x:Name="BtnAddFilter" Grid.Row="2" Content="+" Width="30" Height="25" 
                HorizontalAlignment="Left" Click="AddFilter_Click" 
                ToolTip="Add prefix filter (max 4)"/>

        <!-- RichTextBox for log -->
        <RichTextBox x:Name="LogViewerBox" Grid.Row="2" Margin="40,0,0,0" 
                     Background="#0a0a0a" FontFamily="Consolas" FontSize="12" 
                     IsReadOnly="True" VerticalScrollBarVisibility="Auto"/>
    </Grid>
</Window>