<Window x:Class="AskaServerManager.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About" Height="350" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#121212">

    

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="ASKA Dedicated Server Manager" 
                   FontSize="18" FontWeight="Bold" Foreground="#D4A017" 
                   HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <TextBlock x:Name="VersionText" Grid.Row="1" 
                   FontSize="14" Foreground="#C8A87C"
                   HorizontalAlignment="Center" Margin="0,0,0,5"/>

        <TextBlock Grid.Row="2" Text="Developer: zloj" 
                   FontSize="14" Foreground="#C8A87C"
                   HorizontalAlignment="Center" Margin="0,0,0,5"/>

        <TextBlock x:Name="DotNetVersionText" Grid.Row="3" 
                   FontSize="11" Foreground="#666666"
                   HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <StackPanel Grid.Row="4" VerticalAlignment="Center">
            <TextBlock Text="Independent administration tool." 
                       FontSize="12" Foreground="#888888" HorizontalAlignment="Center" TextAlignment="Center"/>
            <TextBlock Text="Not affiliated with Sand Sailor Studio." 
                       FontSize="10" Foreground="#555555" HorizontalAlignment="Center" 
                       FontStyle="Italic" Margin="0,5,0,10"/>
        </StackPanel>

        <Button Grid.Row="5"
        Content="OK"
        Click="OkButton_Click">
            <Button.Style>
                <Style TargetType="Button">
                    <!-- Базовые визуальные свойства -->
                    <Setter Property="Width" Value="100"/>
                    <Setter Property="Height" Value="32"/>
                    <Setter Property="HorizontalAlignment" Value="Center"/>
                    <Setter Property="Background" Value="#2d2d2d"/>
                    <Setter Property="Foreground" Value="#D4A017"/>
                    <Setter Property="BorderBrush" Value="#555555"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="Margin" Value="5,0,5,0"/>
                    <Setter Property="Padding" Value="12,6"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="FontWeight" Value="Normal"/>
                    <Setter Property="Cursor" Value="Hand"/>

                    <!-- Переопределённый шаблон кнопки -->
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                                    <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                </Border>

                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#D4A017"/>
                                        <Setter Property="Foreground" Value="#3a3a3a"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#b8860b"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="border" Property="Background" Value="#2a2a2a"/>
                                        <Setter Property="Foreground" Value="#666666"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Button.Style>
        </Button>
    </Grid>
</Window>