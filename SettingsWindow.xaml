<Window x:Class="AskaServerManager.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" 
        Width="600" Height="540"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#FF2E2E2E" Foreground="#E0E0E0"
        FontFamily="Segoe UI" FontSize="13"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <!-- Styles – exact copy from original SettingsWindow.xaml (dark theme) -->
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="#D4A017"/>
            <Setter Property="Margin" Value="0,10,0,10"/>
            <Setter Property="BorderBrush" Value="#3a3a3a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,15,10,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Border BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Background="#252525" CornerRadius="6">
                            <Border BorderBrush="#3a3a3a" BorderThickness="1" CornerRadius="5" Margin="1">
                                <StackPanel>
                                    <TextBlock Text="{TemplateBinding Header}" 
                                               Margin="10,5,10,0" 
                                               Foreground="{TemplateBinding Foreground}"
                                               FontWeight="{TemplateBinding FontWeight}"
                                               FontSize="{TemplateBinding FontSize}"/>
                                    <ContentPresenter Margin="{TemplateBinding Padding}"/>
                                </StackPanel>
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="#2d2d2d"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#D4A017"/>
            <Setter Property="SelectionBrush" Value="#D4A017"/>
            <Setter Property="SelectionOpacity" Value="0.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#D4A017"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#D4A017"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="5,0,5,0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Background" Value="#3a3a3a"/>
            <Setter Property="Foreground" Value="#D4A017"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#D4A017"/>
                                <Setter Property="Foreground" Value="#1e1e1e"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#b8860b"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#2a2a2a"/>
                                <Setter Property="Foreground" Value="#666666"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BrowseButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="70"/>
            <Setter Property="Margin" Value="8,0,0,8"/>
            <Setter Property="Padding" Value="8,0"/>
        </Style>

        <Style x:Key="SmallTextBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Width" Value="150"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
            <StackPanel>
                <!-- Server Paths -->
                <GroupBox Header="Server Paths">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Server folder:" VerticalAlignment="Center" Margin="0,8,8,8" TextWrapping="Wrap"/>
                        <TextBox x:Name="TxtServerDirectory" Grid.Row="0" Grid.Column="1" Margin="0,8,8,8" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" IsEnabled="True" AllowDrop="False" Focusable="True" IsHitTestVisible="True" IsTabStop="False" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" TextWrapping="NoWrap"/>
                        <Button x:Name="BtnBrowseServerDir" Grid.Row="0" Grid.Column="2" Content="Browse" Style="{StaticResource BrowseButtonStyle}" Click="BrowseServerDir_Click" Margin="0,8,0,8"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Executable file:" VerticalAlignment="Center" Margin="0,8,8,8" TextWrapping="Wrap"/>
                        <TextBox x:Name="TxtServerExecutable" Grid.Row="1" Grid.Column="1" Margin="0,8,8,8" Text="AskaServer.exe" IsEnabled="False" AllowDrop="False" Focusable="False" IsHitTestVisible="False" IsTabStop="False"/>
                        <Button Grid.Row="1" Grid.Column="2" Visibility="Hidden" Width="70" Margin="0,8,0,8"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Configuration file:" VerticalAlignment="Center" Margin="0,8,8,8" TextWrapping="Wrap"/>
                        <TextBox x:Name="TxtPropertiesFileName" Grid.Row="2" Grid.Column="1" Margin="0,8,8,8" AllowDrop="False" Focusable="False" IsEnabled="True"/>
                        <Button x:Name="BtnBrowsePropertiesFile" Grid.Row="2" Grid.Column="2" Content="Browse" Style="{StaticResource BrowseButtonStyle}" Click="BrowsePropertiesFile_Click" Margin="0,8,0,8"/>
                    </Grid>
                </GroupBox>

                <!-- Backup -->
                <GroupBox Header="Backup">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Backup folder:" 
                   VerticalAlignment="Center" Margin="0,8,8,8" TextWrapping="Wrap"/>
                        <TextBox x:Name="TxtBackupDirectory" Grid.Row="0" Grid.Column="1" Margin="0,8,8,8" AllowDrop="False" Focusable="True" IsEnabled="True" IsHitTestVisible="True" IsTabStop="False" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" TextWrapping="NoWrap"/>
                        <Button x:Name="BtnBrowseBackupDir" Grid.Row="0" Grid.Column="2" Content="Browse" 
                Style="{StaticResource BrowseButtonStyle}" Click="BrowseBackupDir_Click" Margin="0,8,0,8"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Backup interval (min):" 
                   VerticalAlignment="Center" Margin="0,8,8,8" TextWrapping="Wrap"/>
                        <TextBox x:Name="TxtBackupIntervalMinutes" PreviewTextInput="NumberValidationTextBox" DataObject.Pasting="PastingHandler" Grid.Row="1" Grid.Column="1" Width="120" 
                 HorizontalAlignment="Left" Style="{StaticResource SmallTextBox}" Margin="0,8,8,8" Text="120"/>
                        <Button Grid.Row="1" Grid.Column="2" Visibility="Hidden" Width="70"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Max number of backups:" 
                   VerticalAlignment="Center" Margin="0,8,8,8" TextWrapping="Wrap"/>
                        <TextBox x:Name="TxtMaxBackupCount" PreviewTextInput="NumberValidationTextBox" DataObject.Pasting="PastingHandler" Grid.Row="2" Grid.Column="1" Width="120" 
                 HorizontalAlignment="Left" Style="{StaticResource SmallTextBox}" Margin="0,8,8,8" Text="10"/>

                        <CheckBox x:Name="ChkBackupOnStop" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" 
                  Content="Create backup before stopping server" 
                  Margin="0,8,0,8" Foreground="#CCCCCC" VerticalAlignment="Center"/>
                    </Grid>
                </GroupBox>

                <!-- Logs -->
                <GroupBox Header="Logs">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Max log size (MB):" 
                                   VerticalAlignment="Center" Margin="0,8,8,8" TextWrapping="Wrap"/>
                        <TextBox x:Name="TxtMaxLogSizeMB" Grid.Row="0" Grid.Column="1" Width="120" 
                                 HorizontalAlignment="Left" Style="{StaticResource SmallTextBox}" PreviewTextInput="NumberValidationTextBox" DataObject.Pasting="PastingHandler" Margin="0,8,8,8" Text="2"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Max number of files:" 
                                   VerticalAlignment="Center" Margin="0,8,8,8" TextWrapping="Wrap"/>
                        <TextBox x:Name="TxtMaxLogFiles" Grid.Row="1" Grid.Column="1" PreviewTextInput="NumberValidationTextBox" DataObject.Pasting="PastingHandler" Width="120" 
                                 HorizontalAlignment="Left" Style="{StaticResource SmallTextBox}" Margin="0,8,8,8" Text="100"/>
                        <CheckBox x:Name="ChkLoadDailyLog" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Content="Load daily log file on start" Margin="0,8,0,8" Foreground="#CCCCCC" VerticalAlignment="Center"/>
                        <CheckBox x:Name="ChkDontSaveServerLog" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" Content="Don't save server log to daily file" Margin="0,0,0,8" Foreground="#CCCCCC" VerticalAlignment="Center"/>
                    </Grid>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button x:Name="BtnSave" Content="Save" Width="110" Click="Save_Click" Margin="0,0,10,0"/>
            <Button x:Name="BtnCancel" Content="Cancel" Width="110" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>