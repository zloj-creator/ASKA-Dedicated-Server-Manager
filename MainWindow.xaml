<Window x:Class="AskaServerManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ASKA Dedicated Server Manager" Height="765" Width="670" MinWidth="670" MinHeight="765"
        Closing="Window_Closing"
        Background="#FF555555"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!--0 Menu-->
            <RowDefinition Height="50"/>
            <!--1+2 Server name and buttons-->
            <RowDefinition Height="80"/>
            <RowDefinition Height="0"/>
            <!--3 Host name-->
            <RowDefinition Height="1"/>
            <!--4 InfoPanel-->
            <RowDefinition Height="auto"/>
            <!--5 Log (RichTextBox) -->
            <RowDefinition Height="*"/>
            <!--6 Console -->
            <RowDefinition Height="40"/>
            <!--7 Status bar -->
            <RowDefinition Height="24"/>
        </Grid.RowDefinitions>

        <!-- Menu -->
        <Border Grid.Row="0" BorderBrush="#8B5A2B" Grid.RowSpan="2" Background="#FF555555">
            <Grid>
                <Menu Grid.Row="0" Background="Transparent" Height="130" BorderThickness="3,0,0,0">
                    <MenuItem Header="Server" Background="Transparent">
                        <MenuItem x:Name="MenuStartServer" Header="Start Server" Click="MenuStartServer_Click" Visibility="Collapsed"/>
                        <MenuItem x:Name="MenuStopServer" Header="Stop Server" Click="MenuStopServer_Click" Visibility="Collapsed"/>
                        <MenuItem x:Name="MenuRestartServer" Header="Restart Server" Click="MenuRestartServer_Click" Visibility="Collapsed"/>
                        <MenuItem x:Name="MenuInstall" Header="Install Server" Click="MenuInstall_Click" Visibility="Visible"/>
                        <MenuItem x:Name="MenuUpdate" Header="Update Server" Click="MenuUpdate_Click" Visibility="Collapsed"/>
                        <MenuItem x:Name="MenuValidate" Header="Validate Files" Click="MenuValidate_Click" Visibility="Collapsed"/>
                        <MenuItem x:Name="MenuCheckUpdate" Header="Check for Updates" Click="MenuCheckUpdate_Click" Visibility="Collapsed"/>
                        <MenuItem x:Name="MenuEditConfig" Header="Edit Configuration" Click="MenuEditConfig_Click" Visibility="Collapsed"/>
                    </MenuItem>
                    <MenuItem Header="Log" Background="Transparent">
                        <MenuItem Header="Open Log Folder" Click="OpenLogFolder_Click"/>
                        <MenuItem Header="Save Log" Click="SaveLogToFile"/>
                        <MenuItem Header="Save Log As" Click="SaveLogAs"/>
                        <MenuItem Header="Copy Log to Clipboard" Click="CopyLogToClipboard"/>
                        <MenuItem Header="Show server log" x:Name="MenuShowServerLog" IsCheckable="True" IsChecked="False" Click="ToggleServerLog_Click"/>
                        <MenuItem Header="Clear Log" Click="ClearLog_Click"/>
                    </MenuItem>
                    <MenuItem Header="Help" Background="Transparent">
                        <MenuItem Header="FAQ" Click="Faq_Click"/>
                        <MenuItem Header="About" Click="About_Click"/>
                    </MenuItem>
                </Menu>

                <!--Server name and buttons-->
                <Grid Grid.Row="1">
                    <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtDisplayName" Text="DISPLAY NAME" Foreground="#D4A017" FontSize="36" FontWeight="Bold" FontFamily="Verdana" Margin="20,20,0,0"/>
                        <TextBlock x:Name="TxtServerName" Text="SERVER NAME" Foreground="#C8A87C" FontSize="16" FontStyle="Italic" Margin="25,0,0,0"/>
                    </StackPanel>

                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                        <Button x:Name="BtnOpenSavesFolder" Content="📁" Width="30" Height="30" 
                                Background="Transparent" Foreground="#D4A017" BorderBrush="Transparent" 
                                BorderThickness="1" FontSize="20" Margin="2,0,0,0" Cursor="Hand" 
                                ToolTip="Saves Folder" Style="{StaticResource FlatButtonStyle}"/>
                        <Button x:Name="BtnOpenBackupsFolder" Content="💾" Width="30" Height="30" 
                                Background="Transparent" Foreground="#D4A017" BorderBrush="Transparent" 
                                BorderThickness="1" FontSize="20" Margin="2,0,0,0" Cursor="Hand" 
                                ToolTip="Backups Folder" Style="{StaticResource FlatButtonStyle}"/>
                        <Button x:Name="BtnSettings" Content="⚙️" Width="30" Height="30" 
                                Background="Transparent" Foreground="#D4A017" BorderBrush="Transparent" 
                                BorderThickness="1" FontSize="20" Margin="2,0,0,0" Cursor="Hand" 
                                ToolTip="Settings" Style="{StaticResource FlatButtonStyle}"/>
                        <Ellipse x:Name="StatusLed" Width="18" Height="18" Fill="Gray" VerticalAlignment="Center" Margin="8,3,0,0" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
        <!-- InfoPanel -->
        <Border Grid.Row="4" x:Name="InfoPanel" Background="#1a1a1a" BorderBrush="#ff6600" BorderThickness="2" CornerRadius="6" Padding="12" Margin="20,0,20,0" VerticalAlignment="Center">
            <StackPanel>
                <StackPanel x:Name="UnconfiguredPanel" Visibility="Visible">
                    <TextBlock Text="⚠️ WARNING" Foreground="#ffaa00" FontWeight="Bold" FontSize="13" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                    <TextBlock Text="Settings are not configured!" Foreground="White" FontSize="11" TextWrapping="Wrap" TextAlignment="Center"/>
                    <TextBlock Text="Click the ⚙️ button and specify correct paths." Foreground="#aaaaaa" FontSize="10" Margin="0,4,0,0" TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>
                <StackPanel x:Name="ServerMissingPanel" Visibility="Collapsed">
                    <TextBlock Text="⚠️ SERVER NOT INSTALLED" Foreground="#ffaa00" FontWeight="Bold" FontSize="13" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                    <TextBlock Text="The dedicated server is not yet installed." Foreground="White" FontSize="11" TextWrapping="Wrap" TextAlignment="Center"/>
                    <TextBlock Text="Click 'Server → Install Server' in the menu to install." Foreground="#aaaaaa" FontSize="10" Margin="0,4,0,0" TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>
                <StackPanel x:Name="ServerInfoPanel" Visibility="Collapsed">
                    <StackPanel Margin="0,0,0,8" HorizontalAlignment="Center">
                        <Grid>
                            <TextBlock x:Name="TxtStats" Text="Players: N/A | Time: 00:00 | Season: N/A | Villagers: N/A | Days Survived: N/A" Foreground="#aaaaaa" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" Width="470" TextAlignment="Center"/>
                        </Grid>
                        <TextBlock x:Name="TxtPlayerNames" Text="" Foreground="LightGray" FontSize="14" Margin="0,3,0,0" TextWrapping="Wrap" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <TextBlock x:Name="TxtServerRam" Text="RAM: 0 MB" Foreground="#aaaaaa" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        <Grid Margin="0,6,0,3" HorizontalAlignment="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Server offline во второй строке -->
                            <TextBlock x:Name="TxtServerStatus" Grid.Row="1" Grid.Column="0"
               Text="=== Server offline ===" Foreground="#FF00A512"
               FontSize="14" Margin="0,4,0,0" FontWeight="Bold" TextAlignment="Center"/>

                            <!-- Остальные элементы остаются в строке 0 (если не указано иное) -->
                            <TextBlock x:Name="TxtBackupTimer" Grid.Row="0" Grid.Column="1"
               Text="Until backup: --:--" Foreground="#aaaaaa" FontSize="12"
               Margin="0,0,8,0" FontWeight="SemiBold"/>

                            <TextBlock x:Name="TxtBackupInfo" Grid.Row="0" Grid.Column="2"
               Text="" Foreground="#aaaaaa" FontSize="12" FontWeight="SemiBold"
               ToolTip="Last backup / total size"/>
                        </Grid>
                        <ProgressBar x:Name="BackupProgress" Width="280" Height="2" Value="100" Background="#333" Foreground="#0078d4"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Log (RichTextBox and ScrollViewer) -->
        <Border Grid.Row="5" BorderBrush="#333" BorderThickness="1" CornerRadius="3" Margin="20,10,20,0">
            <ScrollViewer x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <ScrollViewer.CacheMode>
                    <BitmapCache/>
                </ScrollViewer.CacheMode>
                <ScrollViewer.BindingGroup>
                    <BindingGroup/>
                </ScrollViewer.BindingGroup>
                <RichTextBox x:Name="LogBox" 
                         Style="{StaticResource ConsoleLogStyle}"
                         IsReadOnly="True"
                         IsUndoEnabled="False"
                         Background="#FF1F1F1F" 
                         FontFamily="Consolas" 
                         FontSize="12" 
                         VerticalScrollBarVisibility="Disabled"
                         HorizontalScrollBarVisibility="Disabled">
                    <FlowDocument PagePadding="5,0,5,0">
                    </FlowDocument>

                    <RichTextBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Copy" Click="CopyLogToClipboard"/>
                            <MenuItem Header="Save Log" Click="SaveLogToFile"/>
                            <MenuItem Header="Save As" Click="SaveLogAs"/>
                        </ContextMenu>
                    </RichTextBox.ContextMenu>
                </RichTextBox>
            </ScrollViewer>
        </Border>

        <!-- Console: outer Grid for Border and Button -->
        <Grid Grid.Row="6" Margin="20,4,20,8">
            <!-- Border wrapper -->
            <Border Background="#FF272727" BorderBrush="#333" BorderThickness="2" Height="28">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <!-- 1. Prefix -->
                        <ColumnDefinition Width="*"/>
                        <!-- 2. Input field -->
                        <ColumnDefinition Width="Auto"/>
                        <!-- 3. Button -->
                    </Grid.ColumnDefinitions>

                    <!-- PREFIX -->
                    <TextBlock x:Name="ModeLabel" 
                       Grid.Column="0" 
                       Text="[cmd] >" 
                       Foreground="#00ff00" 
                       VerticalAlignment="Center" 
                       Margin="10,0,5,0"/>

                    <!-- INPUT FIELD (CONSOLE) -->
                    <TextBox x:Name="ConsoleInput"
                     PreviewKeyDown="ConsoleInput_PreviewKeyDown"        
                     Background="Transparent" 
                     BorderThickness="0" 
                     Foreground="#00ff00" 
                     CaretBrush="White" 
                     VerticalContentAlignment="Center" Grid.ColumnSpan="2" Margin="60,-4,0,-4"/>

                    <!-- BUTTON -->
                    <Button x:Name="BtnSendCommand" 
                    Grid.Column="2" 
                    Content="➡️"
                    FontSize="18"        
                    Width="30" 
                    Height="24"
                    Background="{x:Null}" 
                    Foreground="#D4A017" 
                    BorderThickness="0,0,0,0" 
                    Margin="5,-3,0,0" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Status bar -->
        
        <StatusBar Grid.Row="7" Background="#1e1e1e" Height="24" Padding="1,0,0,0" VerticalAlignment="Center">
            <StatusBarItem>
                <TextBlock x:Name="StatusBarText" Foreground="#888888" FontSize="10" Margin="2,0,0,0">Ready</TextBlock>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="VersionText" Text="" Foreground="#555555" FontSize="9" Padding="0,0,1,0" Margin="0,0,0,0"/>
            </StatusBarItem>
        </StatusBar>
        
    </Grid>
</Window>